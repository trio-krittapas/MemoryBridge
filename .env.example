# MemoryBridge Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# LLM Configuration (Development: use Ollama, Production: use OpenAI)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Spotify Configuration (Optional for demo, required for Phase 4)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Python Sidecar (Optional, for speech analysis)
PYTHON_SIDECAR_URL=http://localhost:8000

# OpenAI Configuration (Production only)
OPENAI_API_KEY=your-openai-api-key-here

# Feature Flags
NEXT_PUBLIC_ENABLE_SPEECH=true
NEXT_PUBLIC_ENABLE_MUSIC=true
NEXT_PUBLIC_ENABLE_EXERCISES=true
